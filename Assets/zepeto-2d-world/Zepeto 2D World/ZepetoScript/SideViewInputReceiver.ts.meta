    if (UnityEngine_1.Input.GetKey(UnityEngine_1.KeyCode.RightArrow) || UnityEngine_1.Input.GetKey(UnityEngine_1.KeyCode.D))\\r\\n               
    x += 1;\\r\\n            if (UnityEngine_1.Input.GetKey(UnityEngine_1.KeyCode.LeftArrow)
