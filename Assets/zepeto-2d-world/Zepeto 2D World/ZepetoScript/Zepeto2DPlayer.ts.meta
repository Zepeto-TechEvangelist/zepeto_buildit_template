    this._wm = null;\\r\\n        this._ownerPlayer = null;\\r\\n        this._cachedUserId
    = null;\\r\\n        this.profileCardSortOrder = 10;\\r\\n    }\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    // Input API\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    /** Called by your input receiver. */\\r\\n    ApplyInput(dir) {\\r\\n       
    this._input = dir;\\r\\n    }\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    // Lifecycle\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    Start() {\\r\\n        this._wm = Zepeto2DWorldManager_1.default.Instance ??
    null;\\r\\n        this.TryBindOwner();\\r\\n        // Ensure a small 3D capsule
    exists for visual purposes (optional)\\r\\n        this._capsule = this.GetComponentInChildren($typeof(UnityEngine_1.CapsuleCollider));\\r\\n       
    if (!this._capsule) {\\r\\n            this._capsule = this.gameObject.AddComponent($typeof(UnityEngine_1.CapsuleCollider));\\r\\n           
    this._capsule.center = new UnityEngine_1.Vector3(0, 0.25, 0);\\r\\n           
    this._capsule.height = 0.5;\\r\\n            this._capsule.radius = 0.32;\\r\\n           
    this._capsule.isTrigger = false;\\r\\n        }\\r\\n        // 3D Rigidbody
    on the visual root (kinematic, no gravity)\\r\\n        this._rb = this.GetComponentInChildren($typeof(UnityEngine_1.Rigidbody));\\r\\n       
    if (!this._rb)\\r\\n            this._rb = this.gameObject.AddComponent($typeof(UnityEngine_1.Rigidbody));\\r\\n       
    this._rb.useGravity = false;\\r\\n        this._rb.isKinematic = true;\\r\\n       
    // Animator on the visual rig\\r\\n        this._anim = this.GetComponentInChildren($typeof(UnityEngine_1.Animator));\\r\\n       
    if (this._anim)\\r\\n            this._anim.applyRootMotion = false;\\r\\n       
    // Create the separate 2D hitbox object (drives actual motion & collisions)\\r\\n       
    if (!this._hitbox2D) {\\r\\n            const go = new UnityEngine_1.GameObject(\\\"Hitbox2D_\\\"
    + this.name);\\r\\n            this._hitbox2D = go.transform;\\r\\n           
    this._hitbox2D.position = this.transform.position;\\r\\n            this._hitbox2D.localRotation
    = UnityEngine_1.Quaternion.identity;\\r\\n            // Mark this hitbox as
    the player's 2D handle\\r\\n            this.player2dHandle = go.AddComponent($typeof(Player2DHandle_1.default));\\r\\n           
    this.player2dHandle.owner = this;\\r\\n            if (Zepeto2DWorldManager_1.default.Instance)
    {\\r\\n                if (Zepeto2DWorldManager_1.default.Instance.LocalHandle
    === this.player2dHandle) {\\r\\n                    this.player2dHandle.isLocal
    = true;\\r\\n                }\\r\\n            }\\r\\n            // Rigidbody2D
    config tuned for top-down 2D movement\\r\\n            this._rb2d = go.AddComponent($typeof(UnityEngine_1.Rigidbody2D));\\r\\n           
    this._rb2d.bodyType = UnityEngine_1.RigidbodyType2D.Dynamic;\\r\\n           
    this._rb2d.gravityScale = 0;\\r\\n            this._rb2d.freezeRotation = true;\\r\\n           
    this._rb2d.collisionDetectionMode = UnityEngine_1.CollisionDetectionMode2D.Continuous;\\r\\n           
    this._rb2d.interpolation = UnityEngine_1.RigidbodyInterpolation2D.Interpolate;\\r\\n           
    this._rb2d.drag = 50;\\r\\n            this._rb2d.angularDrag = 0;\\r\\n           
    // BoxCollider2D roughly matching the 3D capsule\\r\\n            this._box2d
    = go.AddComponent($typeof(UnityEngine_1.BoxCollider2D));\\r\\n            if
    (this._box2d) {\\r\\n                const mat = new UnityEngine_1.PhysicsMaterial2D();\\r\\n               
    mat.bounciness = 0;\\r\\n                mat.friction = 0;\\r\\n               
    this._box2d.sharedMaterial = mat;\\r\\n            }\\r\\n            const w
    = (this._capsule ? this._capsule.radius * 2 : 0.6);\\r\\n            const h
    = (this._capsule ? this._capsule.height : 1.8);\\r\\n            const offY =
    (this._capsule ? this._capsule.center.y : 0.9);\\r\\n            this._box2d.size
    = new UnityEngine_1.Vector2(w, h);\\r\\n            this._box2d.offset = new
    UnityEngine_1.Vector2(0, offY);\\r\\n        }\\r\\n        // Make sure hitbox
    is aligned initially\\r\\n        if (this._hitbox2D) {\\r\\n            this._hitbox2D.position
    = new UnityEngine_1.Vector3(this.transform.position.x, this.transform.position.y,
    0);\\r\\n        }\\r\\n    }\\r\\n    Update() {\\r\\n        // 1) Read input
    and apply a small deadzone\\r\\n        const dead = 0.15;\\r\\n        const
    raw = this._input;\\r\\n        const mag = raw.magnitude;\\r\\n        const
    use = (mag < dead) ? UnityEngine_1.Vector2.zero : raw;\\r\\n        // 2) Quantize
    direction to 8 ways (optional stylistic choice)\\r\\n        const q8 = this.quantize8WithIndex(use);\\r\\n       
    const dir8 = q8.dir;\\r\\n        // 3) Speed from magnitude (walk \u2192 run),
    based on *use* not raw\\r\\n        const t = UnityEngine_1.Mathf.Clamp01(use.magnitude);\\r\\n       
    const speed = UnityEngine_1.Mathf.Lerp(this.walkSpeed, this.runSpeed, t);\\r\\n       
    // 4) Record desired velocity (applied in FixedUpdate)\\r\\n        this._desiredVel
    = new UnityEngine_1.Vector2(dir8.x * speed, dir8.y * speed);\\r\\n        //
    5) Cut inertia immediately if no input\\r\\n        if (this._rb2d && t === 0)
    {\\r\\n            this._rb2d.velocity = UnityEngine_1.Vector2.zero;\\r\\n           
    this._rb2d.angularVelocity = 0;\\r\\n        }\\r\\n        // 6) Animation parameters\\r\\n       
    if (this._anim) {\\r\\n            if (dir8.sqrMagnitude > 0) {\\r\\n               
    this._anim.SetInteger(\\\"State\\\", 102); // Move\\r\\n                this._anim.SetInteger(\\\"MoveState\\\",
    mag >= this.runThreshold ? 1 : 0); // 0 walk, 1 run\\r\\n                this._anim.SetFloat(\\\"MotionSpeed\\\",
    UnityEngine_1.Mathf.Lerp(this.motionSpeedWalk, this.motionSpeedRun, t));\\r\\n           
    }\\r\\n            else if (this._anim.GetInteger(\\\"State\\\") === 102) {\\r\\n               
    // Moving \u2192 Idle once\\r\\n                this._anim.SetInteger(\\\"State\\\",
    1);\\r\\n                this._anim.SetInteger(\\\"MoveState\\\", 0);\\r\\n               
    this._anim.SetFloat(\\\"MotionSpeed\\\", this.motionSpeedWalk);\\r\\n           
    }\\r\\n        }\\r\\n        // 7) Facing (snap instantly; preserve last when
    no input)\\r\\n        if (q8.idx !== -1) {\\r\\n            // Yaw mapping:
    0:E,1:SE,2:S,3:SW,4:W,5:NW,6:N,7:NE\\r\\n            const yawByIdx = [90, 45,
    0, -45, -90, -135, 180, 135];\\r\\n            const yaw = yawByIdx[q8.idx];\\r\\n           
    this.transform.rotation = UnityEngine_1.Quaternion.Euler(0, yaw, 0);\\r\\n       
    }\\r\\n    }\\r\\n    LateUpdate() {\\r\\n        // Render-time sync: place
    the visual root at the 2D hitbox,\\r\\n        // and compute a stable Z from
    current Y (for layered sorting / depth).\\r\\n        if (!this._rb2d)\\r\\n           
    return;\\r\\n        const hp = this._rb2d.transform.position;\\r\\n        this.transform.position
    = new UnityEngine_1.Vector3(hp.x, hp.y, this.computeZFromWorld(hp.y));\\r\\n   
    }\\r\\n    FixedUpdate() {\\r\\n        if (!this._rb2d)\\r\\n            return;\\r\\n       
    // If no desired motion \u2192 fully stop\\r\\n        if (this._desiredVel.sqrMagnitude
    < 1e-6) {\\r\\n            this._rb2d.velocity = UnityEngine_1.Vector2.zero;\\r\\n           
    this._rb2d.angularVelocity = 0;\\r\\n            return;\\r\\n        }\\r\\n       
    // Otherwise drive at the desired velocity (no acceleration lag)\\r\\n       
    this._rb2d.velocity = this._desiredVel;\\r\\n        this._rb2d.angularVelocity
    = 0;\\r\\n    }\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    // Helpers\\r\\n    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\\r\\n   
    /**\\r\\n     * Map world Y to visual Z using the current map's Y-range (via
    WorldManager).\\r\\n     * The Z output is intentionally constrained to [-80
    .. -95] for a subtle parallax.\\r\\n     * Falls back to a large default range
    if bounds are not ready.\\r\\n     */\\r\\n    computeZFromWorld(y) {\\r\\n       
    const wm = this._wm;\\r\\n        const outMin = -80, outMax = -95; // NOTE:
    outMax < outMin on purpose (deeper into negative)\\r\\n        if (wm && wm.GetWorldYRange)
    {\\r\\n            const r = wm.GetWorldYRange();\\r\\n            if (r && r.valid
    && r.maxY > r.minY) {\\r\\n                const t = UnityEngine_1.Mathf.InverseLerp(r.minY,
    r.maxY, y); // 0..1 within current map\\r\\n                return UnityEngine_1.Mathf.Lerp(outMin,
    outMax, t);\\r\\n            }\\r\\n        }\\r\\n        // Fallback range
    when bounds aren't ready yet\\r\\n        const tf = UnityEngine_1.Mathf.InverseLerp(-9999,
    9999, y);\\r\\n        return UnityEngine_1.Mathf.Lerp(outMin, outMax, tf);\\r\\n   
    }\\r\\n    /**\\r\\n     * Quantize a vector to the nearest of 8 cardinal/diagonal
    directions.\\r\\n     * Returns {dir, idx}. idx: 0:E,1:SE,2:S,3:SW,4:W,5:NW,6:N,7:NE;
    -1 if zero.\\r\\n     */\\r\\n    quantize8WithIndex(v) {\\r\\n        if (v.sqrMagnitude
    < 1e-6)\\r\\n            return { dir: UnityEngine_1.Vector2.zero, idx: -1 };\\r\\n       
    const ang = UnityEngine_1.Mathf.Atan2(v.y, v.x); // -\u03C0..\u03C0, 0=+X\\r\\n       
    const step = (UnityEngine_1.Mathf.PI * 2) / 8; // 45\xB0\\r\\n        const idx
    = UnityEngine_1.Mathf.Round((ang + UnityEngine_1.Mathf.PI * 2) / step) % 8; //
    0..7\\r\\n        const q = idx * step;\\r\\n        const x = UnityEngine_1.Mathf.Cos(q),
    y = UnityEngine_1.Mathf.Sin(q);\\r\\n        const invLen = 1 / UnityEngine_1.Mathf.Sqrt(x
    * x + y * y);\\r\\n        return { dir: new UnityEngine_1.Vector2(x * invLen,
    y * invLen), idx };\\r\\n    }\\r\\n    BindZepetoPlayer(player) {\\r\\n       
    if (!player)\\r\\n            return;\\r\\n        this._ownerPlayer = player;\\r\\n       
    this._cachedUserId = player.userId ?? this._cachedUserId;\\r\\n    }\\r\\n   
    OpenProfileCard() {\\r\\n        const player = this.EnsureOwner();\\r\\n       
    if (!player)\\r\\n            return false;\\r\\n        const card = SocialModule?.ProfileCard?.instance;\\r\\n       
    if (!card) {\\r\\n            console.warn(\\\"[Zepeto2DPlayer] ProfileCard instance
    is not ready.\\\");\\r\\n            return false;\\r\\n        }\\r\\n       
    const targetUserId = player.userId ?? this._cachedUserId;\\r\\n        if (!targetUserId
    || targetUserId.length === 0) {\\r\\n            console.warn(\\\"[Zepeto2DPlayer]
    Unable to resolve userId for profile card.\\\");\\r\\n            return false;\\r\\n       
    }\\r\\n        const needClose = this.IsProfileCardOpen(card);\\r\\n        if
    (needClose && !this.TryCloseProfileCard(card)) {\\r\\n            console.warn(\\\"[Zepeto2DPlayer]
    Unable to close existing profile card before opening a new one.\\\");\\r\\n       
    }\\r\\n        const openSucceeded = this.TryInvokeProfileCardOpen(card, targetUserId);\\r\\n       
    if (!openSucceeded) {\\r\\n            console.error(`[Zepeto2DPlayer] Failed
    to open profile card for ${targetUserId}.`);\\r\\n        }\\r\\n        return
