    /** Max run speed (units/sec). */\\r\\n        this.runSpeed = 5.0;\\r\\n       
    /** Walk speed (units/sec). */\\r\\n        this.walkSpeed = 2.2;\\r\\n       
    /** Stick magnitude threshold to switch MoveState to RUN (0..1). */\\r\\n       
