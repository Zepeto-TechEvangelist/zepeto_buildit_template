    \u201CTalk\u201D).\\r\\n     */\\r\\n    SetTarget(target, labelText) {\\r\\n       
    if (this._target === target)\\r\\n            return;\\r\\n        this._target
    = target;\\r\\n        this.setVisible(target !== null);\\r\\n        if (this.label)
